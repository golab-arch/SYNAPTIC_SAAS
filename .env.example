# Server
PORT=3000
NODE_ENV=development
SKIP_AUTH=true

# Firebase Admin (backend)
FIREBASE_PROJECT_ID=synaptic-saas
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Firebase Client (public, served via /api/auth/config)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=synaptic-saas.firebaseapp.com

# Encryption (for BYOK key storage)
ENCRYPTION_KEY=change-this-in-production

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
